APP_ENV=development
HTTP_ADDR=:8080
LOG_LEVEL=info

DATABASE_URL=file:./data/lynxlinkage.db?_pragma=foreign_keys(1)&_pragma=journal_mode(WAL)

CORS_ALLOW_ORIGIN=http://localhost:5173

CONTACT_RPS=0.2
CONTACT_BURST=3

READ_TIMEOUT=10s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=60s

# Optional: forward submissions to email when set.
EMAIL_FROM=
EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
