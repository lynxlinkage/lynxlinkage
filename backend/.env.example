APP_ENV=development
HTTP_ADDR=:8080
LOG_LEVEL=info

# PostgreSQL connection URL. The server runs migrations automatically on
# startup, so the database itself just needs to exist (see README).
DATABASE_URL=postgresql://lynxlinkage:lynxlinkage@localhost:5432/lynxlinkage?sslmode=disable

CORS_ALLOW_ORIGIN=http://localhost:5173

CONTACT_RPS=0.2
CONTACT_BURST=3

# Public job-application endpoint rate limit (per IP).
APPLICATION_RPS=0.1
APPLICATION_BURST=3

# Auth: HMAC secret used to sign session cookies. MUST be set in production
# (a long random string, e.g. `openssl rand -base64 48`). Rotating it
# invalidates every existing session.
SESSION_SECRET=
SESSION_TTL=168h

# Where uploaded candidate artifacts (CVs etc.) live on disk. Make this
# an absolute path or a persistent volume in production. The directory
# is created on startup if missing.
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_FILES=3
MAX_UPLOAD_FILE_BYTES=10485760
# Hard cap on the total request body for the application form. Defaults
# to MAX_UPLOAD_FILES * MAX_UPLOAD_FILE_BYTES + a 2 MiB margin for
# multipart overhead and form fields.
MAX_UPLOAD_TOTAL_BYTES=

# Bumped from prior 10s/15s defaults so multi-MB uploads on slow client
# connections aren't cut mid-stream.
READ_TIMEOUT=60s
WRITE_TIMEOUT=60s
IDLE_TIMEOUT=60s

# Optional: forward submissions to email when set.
EMAIL_FROM=
EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
