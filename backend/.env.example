APP_ENV=development
HTTP_ADDR=:8080
LOG_LEVEL=info

# PostgreSQL connection URL. The server runs migrations automatically on
# startup, so the database itself just needs to exist (see README).
DATABASE_URL=postgresql://lynxlinkage:lynxlinkage@localhost:5432/lynxlinkage?sslmode=disable

CORS_ALLOW_ORIGIN=http://localhost:5173

CONTACT_RPS=0.2
CONTACT_BURST=3

# Public job-application endpoint rate limit (per IP).
APPLICATION_RPS=0.1
APPLICATION_BURST=3

# Auth: HMAC secret used to sign session cookies. MUST be set in production
# (a long random string, e.g. `openssl rand -base64 48`). Rotating it
# invalidates every existing session.
SESSION_SECRET=
SESSION_TTL=168h

# Where uploaded candidate artifacts (CVs etc.) live on disk. Make this
# an absolute path or a persistent volume in production. The directory
# is created on startup if missing.
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_FILES=3
MAX_UPLOAD_FILE_BYTES=10485760
# Hard cap on the total request body for the application form. Defaults
# to MAX_UPLOAD_FILES * MAX_UPLOAD_FILE_BYTES + a 2 MiB margin for
# multipart overhead and form fields.
MAX_UPLOAD_TOTAL_BYTES=

# Bumped from prior 10s/15s defaults so multi-MB uploads on slow client
# connections aren't cut mid-stream.
READ_TIMEOUT=60s
WRITE_TIMEOUT=60s
IDLE_TIMEOUT=60s

# Short name in emails (e.g. application acknowledgments).
APP_NAME=LynxLinkage

# Public site origin for HTML email assets (no trailing slash).
SITE_URL=https://lynxlinkage.com

# Optional: SMTP for outbound mail (e.g. Hostinger). Set SMTP_URL=host:port
# or SMTP_HOST + SMTP_PORT. Use SMTP_USER/SMTP_PASS or SMTP_USERNAME/SMTP_PASSWORD.
#
# Important: joho/godotenv expands $VAR inside double-quoted values. For
# passwords containing $, use single quotes: SMTP_PASS='your$pass' or escape
# each $ as \$.
EMAIL_FROM=noreply@lynxlinkage.com
EMAIL_TO=hello@lynxlinkage.com
SMTP_URL=smtp.hostinger.com:587
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# Aliases (same meaning as SMTP_USER / SMTP_PASS)
SMTP_USERNAME=
SMTP_PASSWORD=
# Inbound (reference only; this server sends via SMTP, not IMAP/POP)
# IMAP_URL=imap.hostinger.com:993
# POP_URL=pop.hostinger.com:995
